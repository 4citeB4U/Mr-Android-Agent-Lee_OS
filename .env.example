# Agent Lee Agentic Operating System - Frontend Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Voice WebSocket URL for LeeWay-Edge-RTC connection
# Local development: ws://localhost:8765/ws
# Production: wss://your-leeway-rtc-domain.com/ws
VITE_VOICE_WS_URL=wss://leeway-edge-rtc.fly.dev/ws

# Firebase Configuration (if needed for auth)
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# VITE_FIREBASE_APP_ID=your-app-id
# VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# leeway API Configuration (backend proxy recommended)
# VITE_leeway_API_KEY=your-leeway-api-key

# Application Mode
# VITE_APP_MODE=production

