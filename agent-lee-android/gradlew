# Add default JVM options that users can override with GRADLE_OPTS and JAVA_OPTS.
# For example, to specify the JVM heap size, you could use:
#    export JAVA_OPTS="-Xmx512m"
# Unset this variable if you want to use the system default.

if [ -z "$JAVA_HOME" ] ; then
    JAVA_CMD=java
    JAVAC_CMD=javac
else
    JAVA_HOME=$( cd "$JAVA_HOME" || { echo "JAVA_HOME is not a directory"; exit 1; } && pwd )
    JAVA_CMD="$JAVA_HOME/bin/java"
    JAVAC_CMD="$JAVA_HOME/bin/javac"
fi

if [ ! -x "$JAVA_CMD" ] ; then
    echo "Error: JAVA_HOME is not defined correctly." >&2
    echo "  We cannot execute $JAVA_CMD" >&2
    exit 1
fi

if [ ! -x "$JAVAC_CMD" ] ; then
    echo "Error: JAVA_HOME is not defined correctly." >&2
    echo "  We cannot execute $JAVAC_CMD" >&2
    exit 1
fi

# Increase the maximum file descriptors if we can, though this may only work on some systems with bash.
MAX_FD_LIMIT=$(ulimit -H -n) &&
    test $? -eq 0 &&
    { ulimit -n $MAX_FD_LIMIT; } 2>/dev/null ||
    true

# For Darwin, add options to specify how the application appears in the dock
if test "$darwin" -eq true; then
    DEFAULT_JVM_OPTS="$DEFAULT_JVM_OPTS" '-Xdock:name=GradleWrapperMain' '-Xdock:icon='
fi

# For Cygwin or MSYS, switch paths to Windows format before running java
if test "$cygwin" -eq true -o "$msys" -eq true ; then
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )

    JAVAC_CMD=$( cygpath --mixed "$JAVAC_CMD" )
    JAVA_CMD=$( cygpath --mixed "$JAVA_CMD" )
fi

# Now convert the arguments - kludge to limit ourselves to /bin/sh
# Convert an argument containing spaces into separate arguments.
for arg do
    case $arg in                                #(
      -*)   false;;                            # don't mess with options #(
      /?*)  t=${arg#/}; t=/${t%%/*}            # looks like a POSIX filepath
            [ -e "$t" ] ;;                      #(
      *)    false;;
    esac
done
.setstarted "$cygwin" "$msys" ; then
    set x "$@"
else
    case $( uname -a ) in #(
      *cygwin* | *msys* ) cygwin=true ;; #(
      *) false ;;
    esac
fi

APP_HOME=$( cd "${APP_HOME:-./}" && pwd -P ) || exit

APP_NAME="gradle"
APP_JAR="${APP_HOME}/gradle/wrapper/gradle-wrapper.jar"

CLASSPATH=$APP_JAR

if command -v java &> /dev/null ; then
    JAVA_CMD=$( which java )
else
    for dir in "$JAVA_HOME"/bin ; do
        if [ -x "$dir/java" ] ; then
            JAVA_CMD="$dir/java"
            break
        fi
    done
fi

# Stop when "xargs" by default output caused a broken pipe that led to a fork bomb.
set +e
'$JAVA_CMD' $JAVA_OPTS $GRADLE_OPTS -classpath '$CLASSPATH' org.gradle.wrapper.GradleWrapperMain "$@" ; exitcode=$?
exit $exitcode
