{
  "name": "@agent-lee/testsprite-agent-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "TestSpriteAgent — QA orchestration: unit/contract/E2E tests, failure summaries.",
  "main": "index.ts",
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/testsprite-agent-mcp/index.js",
    "dev": "ts-node index.ts",
    "test": "vitest run",
    "e2e": "playwright test",
    "preflight": "node Health-Check.ps1 2>&1 || pwsh -File Health-Check.ps1",
    "health": "curl http://localhost:$MCP_AGENT_HTTP_PORT/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "playwright": "^1.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^0.34.0",
    "@types/express": "^4.17.21",
    "tsx": "^4.7.1"
  },
  "mcp": {
    "vs_code_integration": true,
    "logging": {
      "centralized": true,
      "log_dir": "../aaa-helper-agents/log"
    },
    "config": {
      "env_file": ".env.local",
      "required": [
        "MCP_TOOLKIT_PATH"
      ]
    }
  }
}