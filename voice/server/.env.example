# Agent Lee Voice Runtime — Server Config
# Copy this to .env and fill in real values before running.
# The Python server reads this file via pydantic-settings.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765
LOG_LEVEL=INFO

# Comma-separated allowed origins (your Vite dev server + production URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to 1 to run fully offline — no Gemini calls at all (local LLM only)
OFFLINE_MODE=0

# ── Gemini — only called for complex / long turns by RouterAgent ──────────────
# Same key as your GEMINI_API_KEY; Gemini is used sparingly by RouterAgent
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── STT (faster-whisper) ──────────────────────────────────────────────────────
# base.en = fast, English only.  small.en or medium.en for higher accuracy.
WHISPER_MODEL=base.en
# Device: cpu or cuda (if you have a compatible GPU)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Local LLM (llama.cpp) — handles ~90% of turns without Gemini ─────────────
# Download: https://huggingface.co/bartowski/Llama-3.2-1B-Instruct-GGUF
# Place at voice/server/models/llama-3.2-1b-instruct.Q4_K_M.gguf
LLAMA_MODEL_PATH=./models/llama-3.2-1b-instruct.Q4_K_M.gguf
LLAMA_MAX_TOKENS=256
LLAMA_CONTEXT_SIZE=2048
LLAMA_THREADS=4

# ── TTS (Piper) ───────────────────────────────────────────────────────────────
# Install piper: https://github.com/rhasspy/piper/releases
# Place voice model at voice/server/piper_models/en_US-lessac-medium.onnx
PIPER_EXECUTABLE=piper
PIPER_MODEL_PATH=./piper_models/en_US-lessac-medium.onnx
TTS_SAMPLE_RATE=22050

# ── VAD (Silero) ──────────────────────────────────────────────────────────────
VAD_THRESHOLD=0.5
VAD_SAMPLE_RATE=16000
VAD_WINDOW_SIZE_SAMPLES=1536
# Seconds of silence before declaring speech ended
VAD_SILENCE_DURATION=0.8

# ── Router ────────────────────────────────────────────────────────────────────
# Confidence below this threshold → escalate turn to Gemini
ROUTER_GEMINI_THRESHOLD=0.6

# ── Memory (SQLite) ───────────────────────────────────────────────────────────
MEMORY_DB_PATH=./data/memory.db
MEMORY_MAX_CONTEXT_TOKENS=512
